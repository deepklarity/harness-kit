            }
          }
        ],
        "responses": {
          "200": {
            "description": "Task history",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TaskHistory"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/labels": {
