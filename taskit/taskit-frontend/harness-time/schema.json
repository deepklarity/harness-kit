{
  "openapi": "3.0.3",
  "info": {
    "title": "Harness Time - Task Management API",
    "description": "A Trello-like task management service with boards, tasks, users, and labels. All task mutations are recorded in history.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "API root"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Health check endpoints"
    },
    {
      "name": "Users",
      "description": "User management"
    },
    {
      "name": "Boards",
      "description": "Board management"
    },
    {
      "name": "Tasks",
      "description": "Task/Action management"
    },
    {
      "name": "Labels",
      "description": "Label management"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/users": {
      "get": {
        "tags": [
