  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "required": [
          "name",
          "email"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "john@example.com"
          }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "Board": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "tasks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Task"
            }
          }
        }
      },
      "CreateBoardRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "Project Alpha"
          },
          "description": {
            "type": "string",
            "example": "Main project board"
          }
        }
      },
      "UpdateBoardRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "board_id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "dev_eta_seconds": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "description": "Estimated development time in seconds (e.g., 3600 = 1 hour)"
          },
          "assignee_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "assignee": {
            "$ref": "#/components/schemas/User"
          },
          "priority": {
            "type": "string",
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "TODO",
              "IN_PROGRESS",
              "REVIEW",
              "DONE"
            ]
          },
          "created_by": {
            "type": "string",
            "format": "email",
            "description": "Email of user who created the task"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "last_updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "labels": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Label"
            }
          }
        }
      },
      "CreateTaskRequest": {
        "type": "object",
        "required": [
          "board_id",
          "title",
          "description",
          "created_by"
        ],
        "properties": {
          "board_id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string",
            "example": "Implement login feature"
          },
          "description": {
            "type": "string",
            "example": "Add user authentication with JWT tokens"
          },
          "priority": {
            "type": "string",
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ],
            "default": "MEDIUM"
          },
          "created_by": {
            "type": "string",
            "format": "email",
            "example": "john@example.com",
            "description": "Email of user creating the task"
          }
        }
      },
      "UpdateTaskRequest": {
        "type": "object",
        "required": [
          "updated_by"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "dev_eta_seconds": {
            "type": "integer",
            "format": "int64",
            "example": 7200,
            "description": "Estimated development time in seconds (e.g., 7200 = 2 hours)"
          },
          "priority": {
            "type": "string",
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "TODO",
              "IN_PROGRESS",
              "REVIEW",
              "DONE"
            ]
          },
          "assignee_id": {
            "type": "string",
            "format": "uuid"
          },
          "label_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "updated_by": {
            "type": "string",
            "format": "email",
            "example": "john@example.com",
            "description": "Email of user making the update"
          }
        }
      },
      "AssignTaskRequest": {
        "type": "object",
        "required": [
          "assignee_id",
          "updated_by"
        ],
        "properties": {
          "assignee_id": {
            "type": "string",
            "format": "uuid"
          },
          "updated_by": {
            "type": "string",
            "format": "email",
            "example": "john@example.com",
            "description": "Email of user making the assignment"
          }
        }
      },
      "UnassignTaskRequest": {
        "type": "object",
        "required": [
          "updated_by"
        ],
        "properties": {
          "updated_by": {
            "type": "string",
            "format": "email",
