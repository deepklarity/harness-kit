      "put": {
        "tags": [
          "Tasks"
        ],
        "summary": "Update task (all changes are recorded in history)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
