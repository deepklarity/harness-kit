# ============================================================
# No .env file is needed for local development!
# All defaults work out of the box with SQLite + filesystem broker.
# Just run: ./dev.sh (from repo root)
# ============================================================

# --- Django ---
# SECRET_KEY=change-me-in-production   # has a dev default built in
# DEBUG=True                           # default: True

# --- Database ---
# Default: SQLite (zero config). Set USE_SQLITE=False for PostgreSQL:
# USE_SQLITE=False
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=taskit
# DB_USER=postgres
# DB_PASSWORD=admin123

# --- Authentication ---
# Default: disabled. Set AUTH_ENABLED=True to require JWT auth.
# AUTH_ENABLED=False
# JWT_ACCESS_SECONDS=900
# JWT_REFRESH_SECONDS=604800
# CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Odin execution ---
# Default: celery_dag with filesystem broker (no Redis needed).
# ODIN_EXECUTION_STRATEGY=celery_dag   # default
# ODIN_CLI_PATH=odin
# ODIN_WORKING_DIR=/path/to/project/with/.odin

# --- Celery broker ---
# Default: filesystem broker (zero config). Set USE_FILESYSTEM_BROKER=False for Redis:
# USE_FILESYSTEM_BROKER=False
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
